# Runtime database URL. For Neon, use the pooled connection string here.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Migration database URL. For Neon, use the direct non-pooler host here.
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Local dev URL. In production on Vercel, set this to your public domain.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
ADMIN_EMAILS=admin@example.com

# Default AI provider when the browser-side override is empty.
AI_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
