{
  "name": "prompt-workshop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clean": "powershell -NoProfile -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }\"",
    "dev:fresh": "npm run dev:clean && next dev --webpack",
    "build": "next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "openai": "4.103.0",
    "prisma": "^6.19.3",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.17.57",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "eslint": "9.28.0",
    "eslint-config-next": "16.2.6",
    "tsx": "^4.22.3",
    "typescript": "5.8.3"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  }
}
